Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"

  config.vm.define "dev1" do |dev1|
    dev1.vm.hostname = "dev1"
    dev1.vm.network "private_network", ip: "192.168.56.10"
  end

  config.vm.define "dev2" do |dev2|
    dev2.vm.hostname = "dev2"
    dev2.vm.network "private_network", ip: "192.168.56.11"
  end

  config.vm.provision "shell", inline: <<-SHELL
    apt-get update
    apt-get install -y build-essential curl rsync
    if ! command -v cargo >/dev/null 2>&1; then
      curl https://sh.rustup.rs -sSf | sh -s -- -y
    fi
  SHELL
end
